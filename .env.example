# Database (async driver)
DATABASE_URL=postgresql+asyncpg://clinical_ai:clinical_ai_password@localhost:5432/clinical_ai_db

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_MINUTES=1440

# Redis
REDIS_URL=redis://localhost:6379

# LLM — 100% local via Ollama (no cloud API keys needed)
# Run `ollama pull qwen3:8b` once on the host before starting.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Medical AI model weights (optional — features degrade gracefully without them)
# MEDCAT_MODEL_PATH=./models/medcat_model_pack.zip
# MONAI_MODEL_PATH=./models/monai_densenet121.pt

# Features
DEBUG=false
ENABLE_IMAGE_ANALYSIS=true
ENABLE_RAG=true
ENABLE_AGENTS=true
